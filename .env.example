# App runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=3000
FLASK_DEBUG=true

# Nova (onboarding rate limit)
ONBOARDING_LIMIT_PER_MINUTE=120
ONBOARDING_WINDOW_SECONDS=60

# Atlas (payments webhook connector)
PAYMENTS_WEBHOOK_TIMEOUT_SECONDS=15
PAYMENTS_WEBHOOK_MAX_RETRIES=3
PAYMENTS_WEBHOOK_BACKOFF_BASE_SECONDS=1
PAYMENTS_WEBHOOK_EXECUTOR_WORKERS=4

# Echo (SMTP connector)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_RETRY_LIMIT=5
SMTP_BACKOFF_BASE_SECONDS=1
SMTP_EXECUTOR_WORKERS=4
